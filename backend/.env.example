# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Database Configuration (PostgreSQL default)
# The backend will automatically fall back to sqlite:///ai_erp.db if this connection fails
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_erp

# Server Port
PORT=8000
HOST=0.0.0.0
ENV=development
